---
export interface Props {
  data: {
    heading: string;
    subtext?: string | null;
    submitButton: string;
    successMessage: string;
    submissionEndpoint?: string | null;
    siteToken?: string | null;
    supabaseAnonKey?: string | null;
  };
}

const { data } = Astro.props;
---

<section class="py-24 px-6 md:px-12 bg-background" data-dr-section="contact-form">
  <div class="max-w-2xl mx-auto">
    <div class="border border-white/10 p-10 md:p-16">
      
      <h2
        class="font-serif text-3xl md:text-4xl text-primary font-light mb-3"
        data-dr-field="heading"
      >
        {data.heading}
      </h2>

      {data.subtext && (
        <p
          class="text-primary/40 text-sm font-light mb-10 leading-relaxed"
          data-dr-field="subtext"
        >
          {data.subtext}
        </p>
      )}

      <form
        id="contact-form"
        class="flex flex-col gap-6"
        novalidate
        data-endpoint={data.submissionEndpoint || undefined}
        data-token={data.siteToken || undefined}
        data-apikey={data.supabaseAnonKey || undefined}
      >
        <div class="relative pt-5">
          <input
            required
            type="text"
            id="contact-name"
            name="name"
            class="peer w-full border-b border-white/20 py-2 text-sm text-primary outline-none focus:border-gold transition-colors bg-transparent placeholder-transparent"
            placeholder=" "
          />
          <label for="contact-name" class="absolute left-0 top-5 text-sm text-primary/40 transition-all pointer-events-none peer-focus:top-0 peer-focus:text-[10px] peer-focus:text-gold peer-focus:uppercase peer-focus:tracking-widest peer-[&:not(:placeholder-shown)]:top-0 peer-[&:not(:placeholder-shown)]:text-[10px] peer-[&:not(:placeholder-shown)]:uppercase peer-[&:not(:placeholder-shown)]:tracking-widest">
            Full Name
          </label>
        </div>

        <div class="relative pt-5">
          <input
            required
            type="email"
            id="contact-email"
            name="email"
            class="peer w-full border-b border-white/20 py-2 text-sm text-primary outline-none focus:border-gold transition-colors bg-transparent placeholder-transparent"
            placeholder=" "
          />
          <label for="contact-email" class="absolute left-0 top-5 text-sm text-primary/40 transition-all pointer-events-none peer-focus:top-0 peer-focus:text-[10px] peer-focus:text-gold peer-focus:uppercase peer-focus:tracking-widest peer-[&:not(:placeholder-shown)]:top-0 peer-[&:not(:placeholder-shown)]:text-[10px] peer-[&:not(:placeholder-shown)]:uppercase peer-[&:not(:placeholder-shown)]:tracking-widest">
            Email Address
          </label>
        </div>

        <div class="relative pt-5">
          <input
            type="tel"
            id="contact-phone"
            name="phone"
            class="peer w-full border-b border-white/20 py-2 text-sm text-primary outline-none focus:border-gold transition-colors bg-transparent placeholder-transparent"
            placeholder=" "
          />
          <label for="contact-phone" class="absolute left-0 top-5 text-sm text-primary/40 transition-all pointer-events-none peer-focus:top-0 peer-focus:text-[10px] peer-focus:text-gold peer-focus:uppercase peer-focus:tracking-widest peer-[&:not(:placeholder-shown)]:top-0 peer-[&:not(:placeholder-shown)]:text-[10px] peer-[&:not(:placeholder-shown)]:uppercase peer-[&:not(:placeholder-shown)]:tracking-widest">
            Phone Number
          </label>
        </div>

        <div class="relative pt-5">
          <textarea
            id="contact-message"
            name="message"
            rows="4"
            class="peer w-full border-b border-white/20 py-2 text-sm text-primary outline-none focus:border-gold transition-colors bg-transparent placeholder-transparent resize-none"
            placeholder=" "
          ></textarea>
          <label for="contact-message" class="absolute left-0 top-5 text-sm text-primary/40 transition-all pointer-events-none peer-focus:top-0 peer-focus:text-[10px] peer-focus:text-gold peer-focus:uppercase peer-focus:tracking-widest peer-[&:not(:placeholder-shown)]:top-0 peer-[&:not(:placeholder-shown)]:text-[10px] peer-[&:not(:placeholder-shown)]:uppercase peer-[&:not(:placeholder-shown)]:tracking-widest">
            Message
          </label>
        </div>

        <button
          type="submit"
          class="bg-gold text-background py-4 text-[10px] font-medium tracking-[0.3em] uppercase mt-6 hover:bg-primary hover:text-background transition-colors duration-300 flex items-center justify-center gap-3 group"
          data-dr-field="submitButton"
        >
          {data.submitButton}
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </button>

        <p
          id="contact-success-msg"
          class="text-[11px] uppercase tracking-[0.2em] text-gold mt-2 text-center"
          style="display: none;"
          data-dr-field="successMessage"
        >
          {data.successMessage}
        </p>
      </form>

    </div>
  </div>
</section>

<script>
(function () {
  var isPreview = new URLSearchParams(window.location.search).get('preview') === 'true';
  if (isPreview) return;

  var form = document.getElementById('contact-form');
  var successMsg = document.getElementById('contact-success-msg');

  form && form.addEventListener('submit', function (e) {
    e.preventDefault();
    var formEl = e.currentTarget as HTMLFormElement;
    var nameEl = formEl.querySelector('[name="name"]') as HTMLInputElement | null;
    var emailEl = formEl.querySelector('[name="email"]') as HTMLInputElement | null;
    var phoneEl = formEl.querySelector('[name="phone"]') as HTMLInputElement | null;
    var messageEl = formEl.querySelector('[name="message"]') as HTMLTextAreaElement | null;
    var name = nameEl ? nameEl.value.trim() : '';
    var email = emailEl ? emailEl.value.trim() : '';

    if (!name) {
      if (nameEl) nameEl.style.borderColor = '#ef4444';
      return;
    }
    if (!email || !email.includes('@')) {
      if (emailEl) emailEl.style.borderColor = '#ef4444';
      return;
    }

    // Show success message
    if (successMsg) successMsg.style.display = '';
    formEl.reset();

    // Fire-and-forget submission to edge function
    var endpoint = formEl.dataset.endpoint;
    var token = formEl.dataset.token;
    var apikey = formEl.dataset.apikey;
    if (endpoint && token) {
      var hdrs: Record<string, string> = { 'Content-Type': 'application/json' };
      if (apikey) hdrs['apikey'] = apikey;
      fetch(endpoint, {
        method: 'POST',
        headers: hdrs,
        body: JSON.stringify({
          siteToken: token,
          name: name,
          email: email,
          phone: phoneEl ? phoneEl.value.trim() : '',
          message: messageEl ? messageEl.value.trim() : '',
          source_url: window.location.href,
          form_type: 'contact',
        }),
      }).catch(function () { /* non-fatal */ });
    }
  });
})();
</script>
