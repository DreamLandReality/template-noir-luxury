---
export interface Props {
  data: {
    copyright: string;
    branding?: string;
  };
}

const { data } = Astro.props;
---

<footer class="bg-surface border-t border-border py-10 px-6" data-dr-section="footer">
  <div class="max-w-7xl mx-auto flex justify-center items-center text-[11px] uppercase tracking-[0.25em] text-muted">
    <div data-dr-field="copyright" data-dr-style="copyright">
      {data.copyright}
    </div>
  </div>
</footer>
