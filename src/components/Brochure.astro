---
export interface Props {
  data: {
    eyebrow?: string;
    heading?: string;
    body?: string;
    buttonText?: string;
    brochureFile?: string;
    backgroundImage?: string;
    backgroundImageAlt?: string;
  };
}

const { data } = Astro.props;
const imgSrc = (path: string) => path?.startsWith('http') ? path : `/${path}`;
---

<section class="py-24 px-6 md:px-12 bg-surface" data-dr-section="brochure">
  <div class="max-w-4xl mx-auto">
    <div class="border border-white/10 p-12 md:p-16 flex flex-col items-center justify-center gap-6">

      <!-- Document icon -->
      <div class="w-14 h-14 border border-white/15 flex items-center justify-center">
        <svg class="w-6 h-6 text-primary/50" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
      </div>

      <div class="text-center">
        {data.eyebrow && (
          <p
            class="text-[9px] tracking-[0.4em] uppercase text-primary/40 mb-3"
            data-dr-field="eyebrow"
          >
            {data.eyebrow}
          </p>
        )}
        {data.heading && (
          <h2
            class="font-serif text-3xl md:text-4xl text-primary font-light mb-4"
            data-dr-field="heading"
          >
            {data.heading}
          </h2>
        )}
        {data.body && (
          <p
            class="text-primary/60 leading-relaxed font-light max-w-md mx-auto"
            data-dr-field="body"
          >
            {data.body}
          </p>
        )}
      </div>

      <a
        href={data.brochureFile || '#'}
        download={!!data.brochureFile}
        data-gate-trigger="lead-capture"
        data-gate-action="brochure"
        data-gate-mode="download"
        class="flex items-center gap-3 px-10 py-4 bg-primary text-background text-[10px] tracking-[0.3em] uppercase hover:bg-gold hover:text-background transition-all duration-300 w-full justify-center mt-2"
      >
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        <span data-dr-field="buttonText">
          {data.buttonText || 'Download Brochure'}
        </span>
      </a>

      <div
        hidden
        role="status"
        class="w-full max-w-2xl border border-gold/30 bg-gold/5 px-6 py-5 text-left"
        data-gate-feedback="lead-capture"
        data-gate-feedback-action="brochure"
        data-gate-feedback-reason="download_unavailable"
      >
        <div class="flex items-start gap-4">
          <div class="mt-0.5 flex h-9 w-9 flex-shrink-0 items-center justify-center border border-gold/40 text-gold">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
          </div>
          <div>
            <p class="mb-2 text-[9px] uppercase tracking-[0.3em] text-gold/80">
              Request received
            </p>
            <p class="text-sm leading-relaxed text-primary/70" data-gate-feedback-message>
              Thank you. Your details were received, but the brochure is not available yet. Our advisory team will contact you shortly.
            </p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
