---
export interface Props {
  data: {
    headline: string;
    subtext: string;
    tourType: 'iframe' | 'image' | 'video';
    tourUrl: string;
    tourImage: string;
    tourVideo: string;
    videoAutoplay?: boolean;
    videoMuted?: boolean;
  };
}

const { data } = Astro.props;
const imgSrc = (path: string) => path?.startsWith('http') ? path : `/${path}`;
---

<section class="py-24 bg-surface" data-dr-section="tour360" id="tour360">
  <div class="max-w-7xl mx-auto px-8 md:px-12">

    <!-- Section Header -->
    <div class="mb-14">
      <p class="text-[10px] tracking-[0.5em] uppercase text-gold mb-4 font-sans">Virtual Experience</p>
      <h2
        class="font-serif text-4xl md:text-5xl text-primary font-light mb-4"
        data-dr-field="headline"
        data-dr-style="headline"
      >
        {data.headline}
      </h2>
      <div class="w-10 h-[1px] bg-gold mb-5"></div>
      <p
        class="text-muted text-sm leading-relaxed max-w-lg"
        data-dr-field="subtext"
        data-dr-style="subtext"
      >
        {data.subtext}
      </p>
    </div>

    <!-- Hidden field for media type detection -->
    <input type="hidden" data-dr-field="tourType" value={data.tourType} />

    <!-- Tour Container -->
    <div
      class="relative w-full overflow-hidden bg-background"
      style="aspect-ratio: 16/9;"
      id="tour360-container"
      data-dr-media-container="tour360"
    >
      {data.tourType === 'iframe' ? (
        <iframe
          src={data.tourUrl || 'https://my.matterport.com/show/?m=SxQL3iGyoDo'}
          class="w-full h-full border-0"
          allowfullscreen
          allow="fullscreen; accelerometer; gyroscope; magnetometer"
          data-dr-field="tourUrl"
          title="360° Virtual Tour"
        />
      ) : data.tourType === 'video' ? (
        <div class="relative w-full h-full">
          <!-- Video Loading Skeleton -->
          <div 
            id="tour-video-skeleton" 
            class="absolute inset-0 bg-stone-900/20 animate-pulse flex items-center justify-center"
          >
            <div class="w-12 h-12 border-4 border-gold/30 border-t-gold rounded-full animate-spin"></div>
          </div>
          
          <!-- Video Element -->
          <video
            src={data.tourVideo || 'defaults/demo-video.mp4'}
            autoplay={data.videoAutoplay === true}
            muted={data.videoMuted !== false}
            class="w-full h-full object-cover opacity-0 transition-opacity duration-500"
            controls
            data-dr-field="tourVideo"
            onloadeddata="this.style.opacity='1'; document.getElementById('tour-video-skeleton').style.display='none';"
            oncanplay="this.style.opacity='1'; document.getElementById('tour-video-skeleton').style.display='none';"
          >
            Your browser does not support the video tag.
          </video>
        </div>
      ) : (
        <div
          class="panorama-viewer w-full h-full overflow-x-auto overflow-y-hidden cursor-grab select-none"
          id="panorama-viewer"
          style="scrollbar-width: none; -ms-overflow-style: none;"
        >
          <img
            src={imgSrc(data.tourImage || 'defaults/default-hero.jpg')}
            alt="360° Virtual Tour"
            class="h-full w-auto max-w-none"
            style="min-width: 220%;"
            id="panorama-img"
            draggable="false"
            data-dr-field="tourImage"
          />
        </div>
      )}

      <!-- Controls -->
      <div class="absolute top-4 right-4 flex gap-2 z-10">
        <button
          id="fullscreen-btn"
          class="bg-background/80 backdrop-blur-sm text-primary p-2.5 hover:bg-gold hover:text-background transition-all duration-200"
          aria-label="Fullscreen"
          title="Toggle fullscreen"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 8V4m0 0h4M4 4l5 5m11-5h-4m4 0v4m0-4l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
          </svg>
        </button>
      </div>

      <!-- 360 Badge -->
      <div class="absolute top-4 left-4 z-10 bg-background/70 backdrop-blur-sm px-3 py-2 flex items-center gap-2">
        <div class="w-5 h-5 border border-gold rounded-full flex items-center justify-center">
          <span class="text-gold text-[8px] font-bold leading-none">360</span>
        </div>
        <span class="text-[10px] tracking-[0.25em] text-primary uppercase font-sans">Virtual Tour</span>
      </div>
    </div>

    <!-- Hint -->
    <p class="text-muted text-[11px] tracking-[0.2em] uppercase mt-5 text-center font-sans">
      {data.tourType === 'image' ? 'Click and drag to explore the panorama' : data.tourType === 'video' ? 'Watch the video tour' : 'Navigate to explore every corner of the residence'}
    </p>

  </div>
</section>

<script is:inline>
(function () {
  // Fullscreen
  var btn = document.getElementById('fullscreen-btn');
  var container = document.getElementById('tour360-container');
  if (btn && container) {
    btn.addEventListener('click', function () {
      if (!document.fullscreenElement) {
        container.requestFullscreen && container.requestFullscreen();
      } else {
        document.exitFullscreen && document.exitFullscreen();
      }
    });
  }

  // Panoramic image drag viewer
  var viewer = document.getElementById('panorama-viewer');
  var img = document.getElementById('panorama-img');

  if (viewer && img) {
    var isDragging = false;
    var startX = 0;
    var scrollLeft = 0;

    function centerPanorama() {
      viewer.scrollLeft = (img.offsetWidth - viewer.offsetWidth) / 2;
    }

    viewer.addEventListener('mousedown', function (e) {
      isDragging = true;
      viewer.style.cursor = 'grabbing';
      startX = e.pageX - viewer.offsetLeft;
      scrollLeft = viewer.scrollLeft;
      e.preventDefault();
    });

    document.addEventListener('mouseup', function () {
      isDragging = false;
      if (viewer) viewer.style.cursor = 'grab';
    });

    viewer.addEventListener('mousemove', function (e) {
      if (!isDragging) return;
      var x = e.pageX - viewer.offsetLeft;
      viewer.scrollLeft = scrollLeft - (x - startX) * 1.5;
    });

    viewer.addEventListener('touchstart', function (e) {
      isDragging = true;
      startX = e.touches[0].pageX;
      scrollLeft = viewer.scrollLeft;
    }, { passive: true });

    viewer.addEventListener('touchmove', function (e) {
      if (!isDragging) return;
      var x = e.touches[0].pageX;
      viewer.scrollLeft = scrollLeft - (x - startX) * 1.5;
    }, { passive: true });

    viewer.addEventListener('touchend', function () { isDragging = false; });
    img.addEventListener('dragstart', function (e) { e.preventDefault(); });

    if (img.complete) {
      centerPanorama();
    } else {
      img.addEventListener('load', centerPanorama);
    }
  }
})();
</script>
