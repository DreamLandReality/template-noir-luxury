---
import Head from '../components/Head.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getSectionData, isSectionEnabled, getTheme, getStyleOverridesCSS, getStateTypes } from '../lib/manifest-loader';

const theme = getTheme();
const styleOverridesCSS = getStyleOverridesCSS();
const navData = getSectionData<{
  logoText: string;
  logoImageUrl?: string;
  links: { label: string; href: string }[];
}>('navigation');
const footerData = getSectionData<{
  copyright: string;
  branding?: string;
}>('footer');

export interface Props {
  title: string;
  seo: any;
  transparentNav?: boolean;
  gateConfig?: {
    sectionId: string;
    siteToken: string | null;
    submissionEndpoint: string | null;
    supabaseAnonKey: string | null;
  } | null;
}

const { title, seo, transparentNav = false, gateConfig = null } = Astro.props;
const stateTypes = getStateTypes();
---

<!DOCTYPE html>
<html lang={seo.language || 'en'} data-dr-page-id="home">
  <Head title={title} seo={seo} />
  <body class="font-sans antialiased bg-background text-primary selection:bg-gold selection:text-background">
    <style define:vars={{
      primary: theme.colors.primary,
      "primary-foreground": theme.colors.primaryForeground,
      background: theme.colors.background,
      surface: theme.colors.surface,
      muted: theme.colors.muted,
      border: theme.colors.border,
      "font-sans": theme.typography.fontSans,
      "font-serif": theme.typography.fontSerif,
      radius: theme.radius.base,
      accent: theme.colors.accent
    }}>
      :root {
        --primary: var(--primary);
        --primary-foreground: var(--primary-foreground);
        --background: var(--background);
        --surface: var(--surface);
        --muted: var(--muted);
        --border: var(--border);
        --font-sans: var(--font-sans);
        --font-serif: var(--font-serif);
        --radius: var(--radius);
        --accent: var(--accent);
      }
    </style>

    {/* Style overrides from admin panel (responsive font sizes etc.) */}
    {styleOverridesCSS && <style set:html={styleOverridesCSS} />}

    {isSectionEnabled('navigation') && <Nav data={navData} transparentNav={transparentNav} />}

    <main>
      <slot />
    </main>

    {isSectionEnabled('footer') && <Footer data={footerData} />}

    <script is:inline src="/preview-runtime.min.js"></script>
    <script>
      import '../lib/manifest-injector';
    </script>

    {gateConfig && gateConfig.siteToken && (
      <script is:inline define:vars={{ 
        sectionId: gateConfig.sectionId,
        token: gateConfig.siteToken,
        endpoint: gateConfig.submissionEndpoint,
        anonKey: gateConfig.supabaseAnonKey,
        stateTypes: stateTypes
      }}>
        window.__DLR = { sectionId, token, endpoint, anonKey, stateTypes };
      </script>
      <script is:inline src="/gate-runtime.min.js"></script>
    )}
  </body>
</html>
